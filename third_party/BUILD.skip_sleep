package(default_visibility = ["//visibility:public"])

cc_binary(
    name = "skip_sleep",
    srcs = ["tardis.c"],
    target_compatible_with = [
        "@platforms//cpu:x86_64", # Avoid ARM/aarch64
    ],
    data = [":skip_sleep_preload"],
    includes = ["."],
    deps = [":skip_sleep_preload"],
)

cc_binary(
    name = "skip_sleep_preload",
    srcs = ["novdso.c"],
    target_compatible_with = [
        "@platforms//cpu:x86_64", # Avoid ARM/aarch64
    ],
    includes = ["."],
    linkshared = 1,
)
